{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Ecommerce App",
            "program": "${workspaceFolder}/app.js",
            "runtimeArgs": [
                "--nolazy"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "restart": true,
            "console": "integratedTerminal"
        }
    ]
}
