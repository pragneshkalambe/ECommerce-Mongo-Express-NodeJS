<div class="container mt-4">
  <h3>Add Product</h3>

  <form action="/api/admin/products/add" method="POST" enctype="multipart/form-data">

    <!-- Name -->
    <div class="mb-3">
      <label>Name</label>
      <input name="name" class="form-control" required>
    </div>

    <!-- Price -->
    <div class="mb-3">
      <label>Price</label>
      <input name="price" type="number" class="form-control" required>
    </div>

    <!-- Category -->
    <div class="mb-3">
      <label>Category</label>
      <input name="category" class="form-control" required>
    </div>

    <!-- Brand -->
    <div class="mb-3">
      <label>Brand</label>
      <input name="brand" class="form-control" required>
    </div>

    <!-- Description -->
    <div class="mb-3">
      <label>Description</label>
      <textarea name="description" class="form-control" required></textarea>
    </div>

    <!-- Is Mobile -->
    <div class="mb-3">
      <label>Is Mobile Product?</label>
      <select name="isMobile" id="isMobile" class="form-control">
        <option value="false">No</option>
        <option value="true">Yes</option>
      </select>
    </div>

    <!-- Cellular Data -->
    <div class="mb-3" id="cellularBox" style="display:none;">
      <label>Cellular Data (only for mobiles)</label>
      <input name="cellularData" class="form-control" placeholder="4G / 5G">
    </div>

    <!-- Images -->
    <div class="mb-3">
      <label>Product Images</label>
      <input type="file" name="image" multiple class="form-control">
    </div>

    <button class="btn btn-success">Create Product</button>
  </form>
</div>

<script>
  function toggleCellular() {
    const val = document.getElementById("isMobile").value;
    document.getElementById("cellularDiv").classList.toggle("d-none", val !== "true");
  }
</script>


