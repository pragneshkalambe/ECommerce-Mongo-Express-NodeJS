{{#each products}}
<div class="col-lg-4 col-md-6 col-sm-12">
    <div class="card daily-deal-card h-100 shadow-sm">
        <img src="{{this.image.[0]}}" class="card-img-top">

        <div class="card-body text-center">
            <h6>{{this.name}}</h6>

            <p class="small text-muted text-truncate">
                {{this.description}}
            </p>

            <p class="fw-bold text-success">
                ₹{{this.price}}
                <span class="text-danger">30% OFF</span>
            </p>

            <a class="btn btn-sm btn-primary w-100" href="/details/?id={{this._id}}">
                Details
            </a>
        </div>
    </div>
</div>
{{/each}}

