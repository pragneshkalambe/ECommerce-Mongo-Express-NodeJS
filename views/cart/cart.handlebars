<section class="h-100 gradient-custom">
    {{#if isCartEmpty}}
    <div class="row">

        <div class="col-md-12">

            <div class="card">
                <div class="card-header d-flex justify-content-center">
                    <h5><strong> No Products Added , Please Add Products!</strong></h5>
                </div>
                <div class="card-body cart">
                    <div class="col-sm-12 empty-cart-cls text-center">
                        <img src="https://i.imgur.com/dCdflKN.png" width="130" height="130" class="img-fluid mb-4 mr-3">
                        <h3><strong>Your Cart is Empty</strong></h3>
                        <h4>Add something to make me happy :)</h4>



                    </div>
                </div>
            </div>


        </div>

    </div>

    </div>
    {{else}}
    <div class="container py-5">
        <div class="row my-4" data-id="{{this._id}}">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header py-3">
                        <h5 class="mb-0 productsCount">Products : {{cartCount}}</h5>
                    </div>


                    <div class="card-body">
                        {{!-- @foreach (var item in Model.Cart.CartItems) --}}
                        {{!-- { --}}
                        {{#each product}}
                        <!-- Single item -->
                        <div class="row cart-item" data-id="{{this._id}}">
                            <div class="col-lg-3 col-md-12 mb-4 mb-lg-0">
                                <!-- Image -->
                                <div class="bg-image hover-overlay hover-zoom ripple rounded"
                                    data-mdb-ripple-color="light">

                                    {{#each this.image}}
                                    {{#if @first}}
                                    <img src="{{this}}" class="card-img-top">
                                    {{/if}}
                                    {{/each}}
                                    <a href="#!">
                                        <div class="mask" style="background-color: rgba(251, 251, 251, 0.2)"></div>
                                    </a>
                                </div>
                                <!-- Image -->
                            </div>

                            <div class="col-lg-5 col-md-6 mb-4 mb-lg-0">
                                <!-- Data -->
                                <p><strong>{{this.name}}</strong></p>
                                <p>Color: blue</p>
                                <p>Category : {{this.category}}</p>


                                <form action="">

                                    <button type="submit" class="btn btn-primary btn-sm me-1 mb-2"
                                        data-mdb-toggle="tooltip" title="Remove item">
                                        <i class="fa fa-trash" aria-hidden="true"></i>
                                    </button>
                                    <button type="submit" class="btn btn-danger btn-sm mb-2" data-mdb-toggle="tooltip"
                                        title="Move to the wish list">
                                        <i class="fa fa-heart"></i>
                                    </button>


                                </form>

                                <!-- Data -->
                            </div>

                            <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">

                                <div class="d-flex align-items-end mb-4" style="max-width: 300px">

                                    <!-- minus -->
                                    <button class="btn btn-primary px-3 me-2" id="decrementBtn">
                                        <i class="fa fa-minus"></i>
                                    </button>

                                    <!-- quantity -->
                                    <div class="d-flex flex-column text-center">
                                        <label class="form-label mb-1 fw-semibold">Quantity</label>
                                        <input min="1" name="quantity" value="{{this.qty}}" type="number" id="inputQty"
                                            class="form-control text-center qtyInput" style="width: 70px;" />
                                    </div>

                                    <!-- plus -->
                                    <button class="btn btn-primary px-3 ms-2" id="incrementBtn">
                                        <i class="fa fa-plus"></i>
                                    </button>

                                </div>

                                <p class="text-start text-md-center d-flex prod_price" data-price="{{this.price}}">
                                    <strong>Price: <span class="priceValue">{{this.price}}</span></strong>
                                </p>

                                <!-- Price -->

                                <p>

                                    <button type="submit" class="btn btn-primary px-3 ms-2 removeFromCart"
                                        data-mdb-toggle="tooltip" title="Remove item" data-id="{{this._id}}">
                                        Remove
                                    </button>

                                </p>



                            </div>
                        </div>


                        <hr class="my-4" />
                        {{!-- } --}}
                        {{/each}}
                    </div>

                    <p class="text-center">

                        <a href="/" class="btn btn-primary cart-btn-transform m-3" data-abc="true">continue shopping</a>
                        {{!-- <a href="/login" class="btn btn-primary transform m-3">Go To Check Out</a> --}}
                        <a href="/checkout">Go To Checkout</a>

                        

                    </p>

                </div>
            </div>
            <div class="col-md-4">
                {{!-- @Html.Action("CartSummary") --}}
                <div class="card" style="font-family: sans-serif;">
                    <div class="card-header" style="font-family: sans-serif;font-size: 20px;"><strong>Cart
                            Summary</strong></div>
                    <div class="card-body">

                        <ul class="list-group list-group-flush">
                            <li
                                class="list-group-item d-flex justify-content-between align-items-center border-0 px-0 pb-0">
                                Products
                                <span class="cart_ProductsTotal">{{product.length}}</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                Shipping
                                <span>0</span>
                            </li>

                        </ul>
                    </div>
                    <div class="card-footer d-flex justify-content-between" style="font-family: sans-serif;">
                        <div>
                            <strong>Total amount</strong>
                            <strong>
                                <p class="mb-0">(including VAT)</p>
                            </strong>
                        </div>
                        <span class="total_amount"><strong>
                                {{#each product}}
                                {{this.price}}
                                {{/each}}
                            </strong>
                        </span>
                    </div>
                </div>

            </div>
        </div>
    </div>
    {{/if}}
</section>