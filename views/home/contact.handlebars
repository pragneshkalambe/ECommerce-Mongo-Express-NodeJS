<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    
﻿@model ECommerceStore.Domain.Dtos.ContactDto
@{
    ViewBag.Title = "Contact";
}


<div>
    <div class="container">

        <!--Section: Contact v.2-->
        <section class="mb-4">

            <!--Section heading-->
            <h2 class="h1-responsive font-weight-bold text-center my-4">Contact us</h2>
            <!--Section description-->
            <p class="text-center w-responsive mx-auto mb-5">
                Do you have any questions? Please do not hesitate to contact us directly. Our team will come back to you within
                a matter of hours to help you.
            </p>

            <div class="row">

                <!--Grid column-->
                <div class="col-md-9 mb-md-0 mb-5">
                    @using (Html.BeginForm("Contact", "Customer", FormMethod.Post, new { @name = "contact-form" }))
                    {
                        @Html.ValidationSummary(false, "", new { @class = "text-danger" });
                        <!--Grid row-->
                        <div class="row">

                            <!--Grid column-->
                            <div class="col-md-6">
                                <div class="md-form mb-0">
                                    @Html.TextBoxFor(c => c.Name, new { @class = "form-control", @placeholder = "Enter Name" })

                                    <label for="name" class="">Your name</label>
                                    @Html.ValidationMessageFor(c => c.Name, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <!--Grid column-->
                            <!--Grid column-->
                            <div class="col-md-6">
                                <div class="md-form mb-0">
                                    @Html.TextBoxFor(c => c.EmailID, new { @class = "form-control", @placeholder = "Enter Email" })


                                    <label for="email" class="">Your email</label>
                                    @Html.ValidationMessageFor(c => c.EmailID, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <!--Grid column-->

                        </div>
                        <!--Grid row-->
                        <!--Grid row-->
                        <div class="row">
                            <div class="col-md-12">
                                <div class="md-form mb-0">
                                    @Html.TextAreaFor(c => c.Message, new { @class = "form-control", @placeholder = "Enter Message" })


                                    <label for="subject" class="">Subject</label>

                                    @Html.ValidationMessageFor(c => c.Message, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        <!--Grid row-->
                       

                        <div class="text-center text-md-left">
                            <button type="submit" class="btn btn-outline-primary">Send</button>


                        </div>
                
                   
                }
                </div>
                    <!--Grid row-->



                    <div class="status"></div>
                </div>
                <!--Grid column-->
                <!--Grid column-->
                <div class="col-md-3 text-center">
                    <ul class="list-unstyled mb-0">
                        <li>
                            <i class="fas fa-map-marker-alt fa-2x"></i>
                            <p>San Francisco, CA 94126, USA</p>
                        </li>

                        <li>
                            <i class="fas fa-phone mt-4 fa-2x"></i>
                            <p>+ 01 234 567 89</p>
                        </li>

                        <li>
                            <i class="fas fa-envelope mt-4 fa-2x"></i>
                            <p>contact@mdbootstrap.com</p>
                        </li>
                    </ul>
                </div>
                <!--Grid column-->

        </div>

        </section>
        <!--Section: Contact v.2-->

    </div>



    </div>

</body>
</html>
