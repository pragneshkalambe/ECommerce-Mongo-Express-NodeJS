<form action="/add-address" method="POST" class="p-4">

  <h4>Add Delivery Address</h4>

  <input name="label" placeholder="Home / Office" class="form-control mb-2">

  <input name="city" placeholder="City" class="form-control mb-2" required>

  <input name="state" placeholder="State" class="form-control mb-2" required>

  <input name="country" placeholder="Country" class="form-control mb-2" required>

  <input name="zipcode" placeholder="Zipcode" class="form-control mb-2" required>

  <button type="submit" class="btn btn-primary">Save Address</button>

</form>
