<section class="vh-100">
    <div class="container-fluid h-custom">
        <div class="row d-flex justify-content-center align-items-center h-100">

            <div class="col-md-9 col-lg-6 col-xl-5">
                <img src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-login-form/draw2.webp"
                    class="img-fluid" alt="Sample image">
            </div>
            <div class="col-md-8 col-lg-6 col-xl-4 offset-xl-1">

                <div class="d-flex flex-row align-items-center justify-content-center justify-content-lg-start">
                    <p class="lead fw-normal mb-0 me-3">Sign in with</p>
                    <button type="button" class="btn btn-primary btn-floating mx-1">
                        <i class="fa-brands fa-facebook-f"></i>

                    </button>

                    <button type="button" class="btn btn-primary btn-floating mx-1">
                        <i class="fab fa-twitter" aria-hidden="true"></i>

                    </button>

                    <button type="button" class="btn btn-primary btn-floating mx-1">
                        <i class="fab fa-instagram"></i>
                    </button>

                    <a href="/auth/google">
                        <i class="fab fa-google-plus-g"></i>
                    </a>

                </div>

                <div class="divider d-flex align-items-center my-4">
                    <p class="text-center fw-bold mx-3 mb-0">Or</p>
                </div>

                <form class="d-flex flex-column" method="post" action="/login" id="loginForm" style="width: 380px;">
                    {{#if errorMsg}}
                    <div class="alert alert-danger border border-black">
                        {{errorMsg}}
                    </div>
                    {{/if}}

                    <!-- Email -->
                    <div class="form-outline mb-4">
                        <label class="form-label text-black">Email address :</label>
                        <input type="text" id="emailInp" name="email" value="{{oldData.email}}"
                            class="form-control bg-white border border-black emailInp">
                    </div>

                    <!-- Password -->
                    <div class="form-outline mb-3">
                        <label class="form-label text-black">Password :</label>
                        <input type="password" id="passwordInp" name="password"
                            class="form-control bg-white border border-black passwordInp">
                    </div>

                    <!-- Remember + Forgot -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label text-black" for="rememberMe">
                                Remember me
                            </label>
                        </div>

                        <a href="#" class="text-body text-black">Forgot password?</a>
                    </div>

                    <!-- Login button -->
                    <button type="submit" class="btn btn-primary btn-lg mb-3">
                        Login
                    </button>

                    <p class="small fw-bold text-center">
                        Don't have an account?
                        <a href="/signUp">Sign Up</a>
                    </p>

                </form>

